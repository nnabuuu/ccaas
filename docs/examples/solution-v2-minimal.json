{
  "$schema": "https://ccaas.dev/schemas/solution.v2.json",
  "schemaVersion": "2.0",

  "ccaas": {
    "tenant": {
      "name": "My Solution",
      "slug": "my-solution",
      "description": "A minimal CCAAS solution"
    },
    "discovery": {
      "enabled": true,
      "mode": "auto",
      "skills": [
        {
          "name": "My Skill",
          "slug": "my-skill",
          "description": "Does something useful",
          "skillFile": "skills/my-skill/SKILL.md",
          "triggers": [
            { "type": "keyword", "value": "help", "priority": 10 }
          ],
          "allowedTools": ["write_output"]
        }
      ],
      "mcpServers": {
        "my-tools": {
          "command": "node",
          "args": ["mcp-server/dist/index.js"],
          "description": "Solution MCP tools"
        }
      }
    }
  }
}
