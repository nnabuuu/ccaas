{
  "$schema": "https://ccaas.dev/schemas/solution.v2.json",
  "schemaVersion": "2.0",

  "ccaas": {
    "tenant": {
      "name": "Quiz Analyzer",
      "slug": "quiz-analyzer",
      "description": "Educational quiz analysis system with knowledge point tagging, solution generation, and wrong answer analysis"
    },
    "discovery": {
      "enabled": true,
      "mode": "auto",
      "skills": [
        {
          "name": "Quiz Analyzer - Three Column Analysis",
          "slug": "three-column-analysis",
          "description": "Analyze quiz with three-column layout: parse, search knowledge points, generate solution approach",
          "skillFile": "skills/three-column-analysis/SKILL.md",
          "scope": "tenant",
          "instructions": "Follow the standard workflow in SKILL.md. Use progressive output updates.",
          "triggers": [
            { "type": "keyword", "value": "analyze this quiz", "priority": 11 },
            { "type": "keyword", "value": "start analysis", "priority": 10 },
            { "type": "keyword", "value": "quiz analysis", "priority": 9 }
          ],
          "allowedTools": [
            "parse_quiz_content",
            "search_knowledge_points_json",
            "search_catalog",
            "write_output",
            "generate_thinking_process_template",
            "verify_knowledge_point_tags"
          ]
        },
        {
          "name": "Quiz Analyzer - Knowledge Point Matching",
          "slug": "knowledge-point-matching",
          "description": "Tag quiz questions with relevant knowledge points from the curriculum tree",
          "skillFile": "skills/knowledge-point-matching/SKILL.md",
          "scope": "tenant",
          "triggers": [
            { "type": "keyword", "value": "tag knowledge points", "priority": 10 },
            { "type": "keyword", "value": "knowledge points", "priority": 8 }
          ],
          "allowedTools": [
            "write_output",
            "get_knowledge_points_tree",
            "verify_knowledge_point_tags",
            "search_knowledge_points"
          ]
        },
        {
          "name": "Quiz Analyzer - Student Answer Analysis",
          "slug": "analyze-student-answer",
          "description": "Analyze student answers to identify error types, error steps, and error patterns",
          "skillFile": "skills/analyze-student-answer/SKILL.md",
          "scope": "tenant",
          "triggers": [
            { "type": "keyword", "value": "analyze student answer", "priority": 10 },
            { "type": "keyword", "value": "check this answer", "priority": 9 }
          ],
          "allowedTools": [
            "analyze_student_answer",
            "get_quiz_details",
            "search_knowledge_points",
            "recommend_by_error_pattern"
          ],
          "outputFormat": "StudentAnswer"
        }
      ],
      "mcpServers": {
        "quiz-analyzer-tools": {
          "command": "node",
          "args": ["mcp-server/dist/index.js"],
          "description": "Quiz Analyzer MCP tools for knowledge point analysis and quiz processing",
          "type": "stdio",
          "env": {
            "MCP_PORT": "3006"
          }
        }
      }
    }
  },

  "internal": {
    "backend": {
      "port": 3005,
      "ccaasUrl": "http://localhost:3001",
      "database": {
        "type": "sqlite",
        "path": "data/quiz-analyzer.db"
      }
    },
    "frontend": {
      "port": 5282,
      "apiBaseUrl": "http://localhost:3005"
    },
    "syncFields": [
      "parsedQuiz",
      "catalog",
      "difficulty",
      "quizAnalysis",
      "knowledgePointTags",
      "thinkingProcess",
      "solutionSteps",
      "correctAnswer",
      "commonMistakes",
      "knowledgeGapAnalysis",
      "difficultyAnalysis",
      "relatedQuizzes"
    ],
    "setup": {
      "skipSteps": [],
      "customScripts": {
        "preInstall": ".solution-hooks/pre-install.sh",
        "customInit": ".solution-hooks/custom-init.sh",
        "postInstall": ".solution-hooks/post-install.sh"
      }
    }
  }
}
