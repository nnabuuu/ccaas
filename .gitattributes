# Ensure shell scripts always use LF line endings (prevents /bin/bash^M errors on Linux/macOS
# when scripts are edited on Windows).
*.sh text eol=lf

# Ensure all text files normalize to LF in the repository
* text=auto eol=lf

# Explicitly mark binary files as binary (no EOL conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.db binary
*.sqlite binary
