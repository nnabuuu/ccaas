{
  "name": "@kedge-agentic/chat-interface",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 5190",
    "build": "npm run build:lib",
    "build:lib": "tsc --noEmit -p tsconfig.app.json && vite build --config vite.config.lib.ts",
    "build:app": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "react-markdown": "^9.0.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@kedge-agentic/common": "^0.2.0",
    "@kedge-agentic/react-sdk": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@kedge-agentic/common": "^0.2.0",
    "@kedge-agentic/react-sdk": "^0.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^14.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.3.0",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  }
}
