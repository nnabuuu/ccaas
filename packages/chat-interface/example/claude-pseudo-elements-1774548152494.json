      },
      {
        "selector": ".placeholder\\:text-text-400::placeholder",
        "css": ".placeholder\\:text-text-400::placeholder { --tw-text-opacity: 1; color: hsl(var(--text-400) / var(--tw-text-opacity)); }"
      },
      {
        "selector": ".placeholder\\:text-text-500::placeholder",
        "css": ".placeholder\\:text-text-500::placeholder { --tw-text-opacity: 1; color: hsl(var(--text-500) / var(--tw-text-opacity)); }"
      },
      {
        "selector": ".placeholder\\:text-text-500\\/70::placeholder",
        "css": ".placeholder\\:text-text-500\\/70::placeholder { color: hsl(var(--text-500) / .7); }"
      },
      {
        "selector": ".placeholder\\:opacity-60::placeholder",
        "css": ".placeholder\\:opacity-60::placeholder { opacity: 0.6; }"
      },
      {
        "selector": ".placeholder\\:opacity-75::placeholder",
        "css": ".placeholder\\:opacity-75::placeholder { opacity: 0.75; }"
      },
      {
        "selector": ".placeholder\\:font-base::placeholder",
        "css": ".placeholder\\:font-base::placeholder { font-family: var(--font-ui); font-size: 0.875rem; font-weight: 430; line-height: 1.4; }"
      }
    ],
    "before": [
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { box-sizing: border-box; border-width: 0px; border-style: solid; border-color: currentcolor; }"
      },
      {
        "selector": "::before, ::after",
        "css": "::before, ::after { --tw-content: \"\"; }"
      },
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { --tw-border-spacing-x: 0; --tw-border-spacing-y: 0; --tw-translate-x: 0; --tw-translate-y: 0; --tw-rotate: 0; --tw-skew-x: 0; --tw-skew-y: 0; --tw-scale-x: 1; --tw-scale-y: 1; --tw-pan-x: ; --tw-pan-y: ; --tw-pinch-zoom: ; --tw-scroll-snap-strictness: proximity; --tw-gradient-"
      },
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { border-color: hsl(var(--border-100)); }"
      },
      {
        "selector": ".ProseMirror p.is-editor-empty:first-child::before",
        "css": ".ProseMirror p.is-editor-empty:first-child::before { color: rgb(173, 181, 189); content: attr(data-placeholder); float: left; height: 0px; pointer-events: none; }"
      },
      {
        "selector": ".before\\:absolute::before",
        "css": ".before\\:absolute::before { content: var(--tw-content); position: absolute; }"
      },
      {
        "selector": ".before\\:inset-y-0::before",
        "css": ".before\\:inset-y-0::before { content: var(--tw-content); top: 0px; bottom: 0px; }"
      },
      {
        "selector": ".before\\:left-\\[6px\\]::before",
