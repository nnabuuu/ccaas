{
  "_section": "pseudoElements",
  "cssRules": {
    "selection": [
      {
        "selector": ".code-block__code::selection, .code-block__code span::selection",
        "css": ".code-block__code::selection, .code-block__code span::selection { background-color: hsl(var(--accent-100)); color: hsl(var(--oncolor-100)) !important; }"
      },
      {
        "selector": ".\\[\\&\\:\\:selection\\]\\:bg-transparent::selection",
        "css": ".\\[\\&\\:\\:selection\\]\\:bg-transparent::selection { background-color: transparent; }"
      },
      {
        "selector": ".ProseMirror-hideselection ::selection",
        "css": ".ProseMirror-hideselection ::selection { background: transparent; }"
      }
    ],
    "placeholder": [
      {
        "selector": "input::placeholder, textarea::placeholder",
        "css": "input::placeholder, textarea::placeholder { opacity: 1; color: rgb(156, 163, 175); }"
      },
      {
        "selector": ".placeholder-bg-100\\/40::placeholder",
        "css": ".placeholder-bg-100\\/40::placeholder { color: hsl(var(--bg-100) / .4); }"
      },
      {
        "selector": ".placeholder-text-300::placeholder",
        "css": ".placeholder-text-300::placeholder { --tw-placeholder-opacity: 1; color: hsl(var(--text-300) / var(--tw-placeholder-opacity)); }"
      },
      {
        "selector": ".placeholder-text-400::placeholder",
        "css": ".placeholder-text-400::placeholder { --tw-placeholder-opacity: 1; color: hsl(var(--text-400) / var(--tw-placeholder-opacity)); }"
      },
      {
        "selector": ".placeholder-text-500::placeholder",
