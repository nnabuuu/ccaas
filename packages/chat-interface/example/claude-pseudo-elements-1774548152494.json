      },
      {
        "selector": ".before\\:right-\\[6px\\]::before",
        "css": ".before\\:right-\\[6px\\]::before { content: var(--tw-content); right: 6px; }"
      },
      {
        "selector": ".before\\:-z-\\[1\\]::before",
        "css": ".before\\:-z-\\[1\\]::before { content: var(--tw-content); z-index: -1; }"
      }
    ],
    "after": [
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { box-sizing: border-box; border-width: 0px; border-style: solid; border-color: currentcolor; }"
      },
      {
        "selector": "::before, ::after",
        "css": "::before, ::after { --tw-content: \"\"; }"
      },
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { --tw-border-spacing-x: 0; --tw-border-spacing-y: 0; --tw-translate-x: 0; --tw-translate-y: 0; --tw-rotate: 0; --tw-skew-x: 0; --tw-skew-y: 0; --tw-scale-x: 1; --tw-scale-y: 1; --tw-pan-x: ; --tw-pan-y: ; --tw-pinch-zoom: ; --tw-scroll-snap-strictness: proximity; --tw-gradient-"
      },
      {
        "selector": "*, ::before, ::after",
        "css": "*, ::before, ::after { border-color: hsl(var(--border-100)); }"
      },
      {
        "selector": ".code-block__code .linenumber::after",
        "css": ".code-block__code .linenumber::after { content: attr(data-line-number); user-select: none !important; pointer-events: none !important; }"
      },
      {
        "selector": ".after\\:pointer-events-none::after",
        "css": ".after\\:pointer-events-none::after { content: var(--tw-content); pointer-events: none; }"
      },
      {
        "selector": ".after\\:absolute::after",
        "css": ".after\\:absolute::after { content: var(--tw-content); position: absolute; }"
      },
      {
        "selector": ".after\\:inset-0::after",
        "css": ".after\\:inset-0::after { content: var(--tw-content); inset: 0px; }"
      },
      {
        "selector": ".after\\:-bottom-6::after",
        "css": ".after\\:-bottom-6::after { content: var(--tw-content); bottom: -1.5rem; }"
      },
      {
        "selector": ".after\\:left-0::after",
        "css": ".after\\:left-0::after { content: var(--tw-content); left: 0px; }"
      }
    ],
    "marker": []
  },
  "inputPlaceholder": {
    "placeholderText": "",
    "inputColor": "rgb(250, 249, 245)",
    "inputFontFamily": "\"Anthropic Sans\", system-ui, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
    "inputFontSize": "16px"
  },
  "_summary": {
    "selectionRules": 3,
    "placeholderRules": 14,
    "beforeRules": 10,
    "afterRules": 10,
    "markerRules": 0
  }
