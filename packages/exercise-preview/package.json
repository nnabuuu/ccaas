{
  "name": "@kedge-agentic/exercise-preview",
  "version": "0.2.0",
  "description": "Preview platform for exercise type plugins — CLI sandbox, Admin Playground, public demo.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "exercise-preview": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "default": "./dist/backend/index.js"
    }
  },
  "files": [
    "dist/",
    "web/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
