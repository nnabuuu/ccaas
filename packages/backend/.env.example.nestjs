# Claude Code as a Service - NestJS Configuration

# Server
PORT=3001

# Workspace
WORKSPACE_DIR=.agent-workspace
SESSION_TTL_MS=1800000
MAX_SESSIONS=100
CLEANUP_INTERVAL_MS=300000

# Database (SQLite)
DATABASE_PATH=.agent-workspace/data.db

# Skills
SKILL_REGISTRY_DIR=.skill-packages
DEFAULT_TENANT_ID=default

# Claude CLI (optional overrides)
CLAUDE_COMMAND=claude

# Debug
DEBUG=false
NODE_ENV=development
