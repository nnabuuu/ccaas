# Claude Code as a Service - NestJS Configuration

# Server
PORT=3001

# Workspace
WORKSPACE_DIR=.agent-workspace
SESSION_TTL_MS=1800000
MAX_SESSIONS=100
CLEANUP_INTERVAL_MS=300000

# Database (SQLite)
DATABASE_PATH=.agent-workspace/data.db

# Skills
SKILL_REGISTRY_DIR=.skill-packages
DEFAULT_TENANT_ID=default

# Claude CLI (optional overrides)
CLAUDE_COMMAND=claude

# Admin Account Configuration (for initial setup)
ADMIN_EMAIL=admin@example.com
ADMIN_API_KEY_NAME=Default Admin Key

# Message Queue (Phase 1-4 Implementation)
# Enable database-backed FIFO message queue to prevent race conditions
# WARNING: Changing this in production requires testing - see docs/MESSAGE_QUEUE_IMPLEMENTATION.md
MESSAGE_QUEUE_ENABLED=false           # Enable queue-based message processing (default: false for safe rollout)
MESSAGE_QUEUE_POLL_INTERVAL_MS=1000   # Worker poll interval in milliseconds (default: 1000)
MESSAGE_QUEUE_CONCURRENCY=5           # Max concurrent messages across all sessions (default: 5)
MESSAGE_QUEUE_MAX_RETRIES=2           # Max retry attempts for failed messages (default: 2)

# Debug
DEBUG=false
NODE_ENV=development
