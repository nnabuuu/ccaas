{
  "name": "@kedge-agentic/agent-runtime",
  "version": "0.2.0",
  "private": true,
  "description": "Framework-free runtime for ccaas agentic services. Phase 0: workspace (BaseMaterializer + ContentSource port) + artifact (JsonEditProvider) + interface skeletons for project/schema/sync. Future phases fill in concrete impls for project store, artifact store, schema registry, and bidirectional sync.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./workspace": {
      "types": "./dist/workspace/index.d.ts",
      "default": "./dist/workspace/index.js"
    },
    "./project": {
      "types": "./dist/project/index.d.ts",
      "default": "./dist/project/index.js"
    },
    "./artifact": {
      "types": "./dist/artifact/index.d.ts",
      "default": "./dist/artifact/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "default": "./dist/sync/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
