{
  "name": "@ccaas/react-sdk",
  "version": "1.0.0",
  "description": "React hooks and utilities for integrating with Claude-Code-as-a-Service backend",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-resizable-panels": "^2.0.0",
    "socket.io-client": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "socket.io-client": "^4.7.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "jsdom": "^24.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@ccaas/common": "^1.0.0"
  },
  "keywords": [
    "react",
    "hooks",
    "claude",
    "agent",
    "sdk",
    "socket.io"
  ],
  "author": "",
  "license": "MIT"
}
