{
  "name": "@kedge-agentic/vue-sdk",
  "version": "0.0.1-SNAPSHOT",
  "description": "Vue composables and utilities for integrating with Claude-Code-as-a-Service backend",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "socket.io-client": "^4.0.0",
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vue/test-utils": "^2.4.0",
    "playwright": "^1.57.0",
    "pptxgenjs": "^4.0.1",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "vue": "^3.3.0"
  },
  "dependencies": {},
  "keywords": [
    "vue",
    "composables",
    "claude",
    "agent",
    "sdk",
    "socket.io"
  ],
  "author": "",
  "license": "MIT"
}
