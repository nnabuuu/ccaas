{
  "name": "ccaas",
  "version": "1.0.0",
  "private": true,
  "description": "Claude Code as a Service - Monorepo",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "dev:backend": "npm run start:dev -w @ccaas/backend",
    "dev:admin": "npm run dev -w @ccaas/admin-next",
    "build:shared": "npm run build -w @ccaas/shared",
    "build:backend": "npm run build -w @ccaas/backend",
    "build:admin": "npm run build -w @ccaas/admin-next",
    "build:vue-sdk": "npm run build -w @ccaas/vue-sdk",
    "build:react-sdk": "npm run build -w @ccaas/react-sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
    "code",
    "service",
    "nestjs",
    "vue",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {}
}
