{
  "name": "@kedge-agentic/live-lesson-platform-handlers",
  "private": true,
  "version": "0.1.0",
  "description": "Live-lesson platform-side workflow + ontology handlers. Loaded into ccaas backend at boot via PLATFORM_HANDLER_PACKAGES env. Carved out of @kedge-agentic/backend in Phase 5.5 so core stays solution-free.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "peerDependencies": {
    "@kedge-agentic/backend": "*",
    "@kedge-agentic/observer-engine": "*",
    "@kedge-agentic/ontology": "*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/typeorm": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "typeorm": "^0.3.0",
    "uuid": "^9.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.19.11",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "reflect-metadata": "^0.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@kedge-agentic/backend/(.*)$": "<rootDir>/../../../../packages/backend/dist/src/$1"
    }
  }
}
