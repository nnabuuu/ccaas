# live-lesson creator app — environment variables
#
# Copy to `.env` (Vite auto-loads it). Only `VITE_*` prefixed vars
# are exposed to the browser; this app intentionally exposes NONE.
# All ccaas traffic is proxied through the live-lesson backend's
# CcaasProxyController + CcaasChatProxyController, so the browser
# never sees the ccaas key. See ../backend/.env for CCAAS_API_KEY +
# CCAAS_URL — those are server-side only.

# Vite proxy target for /api/* — points at live-lesson backend.
# Default: http://localhost:3007
BACKEND_URL=http://localhost:3007
