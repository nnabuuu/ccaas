# live-lesson creator app — environment variables
#
# Copy to `.env` (Vite auto-loads it). Only `VITE_*` prefixed vars
# are exposed to the browser.

# Vite proxy target for /api/* — points at live-lesson backend.
# Default: http://localhost:3007
BACKEND_URL=http://localhost:3007

# ccaas backend base URL — used by useProjectChanges hook for the
# agent-runtime SSE change feed (`/api/v1/projects/:projectId/changes`).
# Bypasses the /api/* Vite proxy because the SSE lives on ccaas, not
# the live-lesson backend. Default: http://localhost:3001
VITE_CCAAS_URL=http://localhost:3001
