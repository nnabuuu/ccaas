{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "removeComments": true,
    "strictNullChecks": false,
    "noImplicitAny": false
  },
  "include": ["src/index.ts", "src/common/**/*"],
  "exclude": ["node_modules", "dist", "src/tools", "src/database", "src/main.ts", "src/app.module.ts", "src/types.ts", "src/schemas.ts", "src/similarity.ts"]
}
