{
  "testCases": [
    {
      "id": "test-001",
      "name": "公式应用错误 - 平方差 vs 完全平方",
      "quiz": {
        "id": "quiz-test-001",
        "content": "解方程：x² - 4 = 0（用因式分解法）",
        "correctAnswer": "x = -2 或 x = 2",
        "solutionSteps": [
          "x² - 4 = 0",
          "(x+2)(x-2) = 0",
          "x+2=0 或 x-2=0",
          "x=-2 或 x=2"
        ],
        "knowledgePoints": ["因式分解", "平方差公式", "一元二次方程"]
      },
      "studentAnswer": {
        "content": "解：x² - 4 = 0\n(x-2)² = 0\nx-2 = 0\nx = 2",
        "steps": [
          "x² - 4 = 0",
          "(x-2)² = 0",
          "x-2 = 0",
          "x = 2"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 2,
            "errorType": "formula_misuse",
            "errorDescription": "应该用平方差公式 (a+b)(a-b)=a²-b²，但学生用了完全平方公式 (a-b)²=a²-2ab+b²",
            "affectedKnowledgePoints": ["因式分解", "平方差公式"],
            "severity": "critical",
            "correctApproach": "x²-4 是两项平方差，应使用平方差公式：x²-4 = (x+2)(x-2)"
          }
        ]
      },
      "tags": ["formula_misuse", "factorization", "critical"]
    },
    {
      "id": "test-002",
      "name": "步骤遗漏 - 跳过中间步骤",
      "quiz": {
        "id": "quiz-test-002",
        "content": "化简：(2x+3)(2x-3) - 4x²",
        "correctAnswer": "-9",
        "solutionSteps": [
          "(2x+3)(2x-3) - 4x²",
          "= 4x² - 9 - 4x²",
          "= -9"
        ],
        "knowledgePoints": ["平方差公式", "整式化简", "合并同类项"]
      },
      "studentAnswer": {
        "content": "解：(2x+3)(2x-3) - 4x² = -9",
        "steps": [
          "(2x+3)(2x-3) - 4x² = -9"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": true,
        "errorSteps": [
          {
            "stepNumber": 1,
            "errorType": "step_omission",
            "errorDescription": "跳过了展开和合并同类项的过程，虽然结果正确但步骤不完整",
            "affectedKnowledgePoints": ["平方差公式", "整式化简"],
            "severity": "minor",
            "correctApproach": "应该写出中间步骤：先用平方差公式展开得 4x²-9，再与 -4x² 合并得 -9"
          }
        ]
      },
      "tags": ["step_omission", "simplification", "minor"]
    },
    {
      "id": "test-003",
      "name": "条件遗漏 - 忘记检验增根",
      "quiz": {
        "id": "quiz-test-003",
        "content": "解方程：x/(x-1) = 2",
        "correctAnswer": "x = 2",
        "solutionSteps": [
          "x/(x-1) = 2",
          "x = 2(x-1)",
          "x = 2x - 2",
          "x = 2",
          "检验：当 x=2 时，x-1=1≠0，所以 x=2 是原方程的解"
        ],
        "knowledgePoints": ["分式方程", "增根", "方程检验"]
      },
      "studentAnswer": {
        "content": "解：x/(x-1) = 2\nx = 2(x-1)\nx = 2x - 2\nx = 2",
        "steps": [
          "x/(x-1) = 2",
          "x = 2(x-1)",
          "x = 2x - 2",
          "x = 2"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 4,
            "errorType": "condition_neglect",
            "errorDescription": "忘记检验分数方程的增根，需要验证 x-1≠0",
            "affectedKnowledgePoints": ["分式方程", "增根"],
            "severity": "major",
            "correctApproach": "分式方程求解后必须检验：将 x=2 代入 x-1，得 2-1=1≠0，所以 x=2 是原方程的解"
          }
        ]
      },
      "tags": ["condition_neglect", "fractional_equation", "major"]
    },
    {
      "id": "test-004",
      "name": "计算错误 - 符号错误",
      "quiz": {
        "id": "quiz-test-004",
        "content": "计算：(-2)² + (-3)²",
        "correctAnswer": "13",
        "solutionSteps": [
          "(-2)² + (-3)²",
          "= 4 + 9",
          "= 13"
        ],
        "knowledgePoints": ["有理数乘方", "有理数加法"]
      },
      "studentAnswer": {
        "content": "(-2)² + (-3)² = -4 + -9 = -13",
        "steps": [
          "(-2)² + (-3)²",
          "= -4 + -9",
          "= -13"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 2,
            "errorType": "calculation_error",
            "errorDescription": "负数的平方计算错误，(-2)²应该等于4而不是-4",
            "affectedKnowledgePoints": ["有理数乘方"],
            "severity": "critical",
            "correctApproach": "负数的平方等于正数：(-a)² = a²，所以 (-2)² = 4，(-3)² = 9"
          }
        ]
      },
      "tags": ["calculation_error", "power", "critical"]
    },
    {
      "id": "test-005",
      "name": "概念理解错误 - 混淆绝对值和相反数",
      "quiz": {
        "id": "quiz-test-005",
        "content": "求 -5 的绝对值",
        "correctAnswer": "5",
        "solutionSteps": [
          "|-5| = 5"
        ],
        "knowledgePoints": ["绝对值"]
      },
      "studentAnswer": {
        "content": "|-5| = -5",
        "steps": [
          "|-5| = -5"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 1,
            "errorType": "concept_misunderstanding",
            "errorDescription": "混淆了绝对值和相反数的概念，绝对值总是非负数",
            "affectedKnowledgePoints": ["绝对值"],
            "severity": "critical",
            "correctApproach": "绝对值的定义：|a| 表示数 a 到原点的距离，总是非负数。|-5| = 5"
          }
        ]
      },
      "tags": ["concept_misunderstanding", "absolute_value", "critical"]
    },
    {
      "id": "test-006",
      "name": "步骤顺序错误 - 先合并后化简",
      "quiz": {
        "id": "quiz-test-006",
        "content": "化简：2(x+1) + 3(x-2)",
        "correctAnswer": "5x - 4",
        "solutionSteps": [
          "2(x+1) + 3(x-2)",
          "= 2x + 2 + 3x - 6",
          "= 5x - 4"
        ],
        "knowledgePoints": ["整式化简", "去括号", "合并同类项"]
      },
      "studentAnswer": {
        "content": "2(x+1) + 3(x-2) = 5(x-1) = 5x - 5",
        "steps": [
          "2(x+1) + 3(x-2)",
          "= 5(x-1)",
          "= 5x - 5"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 2,
            "errorType": "step_order_wrong",
            "errorDescription": "应该先去括号再合并同类项，不能直接合并括号前的系数",
            "affectedKnowledgePoints": ["整式化简", "去括号"],
            "severity": "major",
            "correctApproach": "正确顺序：先去括号得 2x+2+3x-6，再合并同类项得 5x-4"
          }
        ]
      },
      "tags": ["step_order_wrong", "simplification", "major"]
    },
    {
      "id": "test-007",
      "name": "推理错误 - 逻辑关系错误",
      "quiz": {
        "id": "quiz-test-007",
        "content": "若 a > b，则下列不等式成立的是：A. a+2 > b+2  B. -a > -b  C. a/2 > b/2  D. 2a < 2b",
        "correctAnswer": "A, C",
        "solutionSteps": [
          "不等式的性质：",
          "1. 两边同时加减同一个数，不等号方向不变 → A正确，C正确",
          "2. 两边同时乘以负数，不等号方向改变 → B错误（应该是 -a < -b）",
          "3. 两边同时乘以正数，不等号方向不变 → D错误（应该是 2a > 2b）"
        ],
        "knowledgePoints": ["不等式的性质", "不等式变形"]
      },
      "studentAnswer": {
        "content": "选B，因为a>b，所以-a>-b",
        "steps": [
          "a > b",
          "所以 -a > -b"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 2,
            "errorType": "reasoning_error",
            "errorDescription": "推理错误：忽略了不等式两边乘以负数时不等号方向要改变的性质",
            "affectedKnowledgePoints": ["不等式的性质"],
            "severity": "critical",
            "correctApproach": "不等式两边同时乘以-1（负数），不等号方向改变：a>b → -a<-b"
          }
        ]
      },
      "tags": ["reasoning_error", "inequality", "critical"]
    },
    {
      "id": "test-008",
      "name": "特殊情况遗漏 - 分类讨论不全",
      "quiz": {
        "id": "quiz-test-008",
        "content": "解不等式：|x| < 3",
        "correctAnswer": "-3 < x < 3",
        "solutionSteps": [
          "|x| < 3",
          "当 x ≥ 0 时，x < 3",
          "当 x < 0 时，-x < 3，即 x > -3",
          "综合：-3 < x < 3"
        ],
        "knowledgePoints": ["绝对值不等式", "分类讨论"]
      },
      "studentAnswer": {
        "content": "|x| < 3，所以 x < 3",
        "steps": [
          "|x| < 3",
          "x < 3"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 2,
            "errorType": "special_case_neglect",
            "errorDescription": "只考虑了 x≥0 的情况，遗漏了 x<0 时需要分类讨论",
            "affectedKnowledgePoints": ["绝对值不等式", "分类讨论"],
            "severity": "major",
            "correctApproach": "绝对值不等式需要分类讨论：x≥0时 x<3，x<0时 -x<3即x>-3，综合得 -3<x<3"
          }
        ]
      },
      "tags": ["special_case_neglect", "absolute_value", "major"]
    },
    {
      "id": "test-009",
      "name": "正确答案 - 无错误",
      "quiz": {
        "id": "quiz-test-009",
        "content": "解方程：2x + 3 = 7",
        "correctAnswer": "x = 2",
        "solutionSteps": [
          "2x + 3 = 7",
          "2x = 7 - 3",
          "2x = 4",
          "x = 2"
        ],
        "knowledgePoints": ["一元一次方程", "移项"]
      },
      "studentAnswer": {
        "content": "解：2x + 3 = 7\n2x = 7 - 3\n2x = 4\nx = 2",
        "steps": [
          "2x + 3 = 7",
          "2x = 7 - 3",
          "2x = 4",
          "x = 2"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": true,
        "errorSteps": []
      },
      "tags": ["correct", "no_error"]
    },
    {
      "id": "test-010",
      "name": "单位换算错误",
      "quiz": {
        "id": "quiz-test-010",
        "content": "一个长方形的长是3米，宽是50厘米，求面积（单位：平方米）",
        "correctAnswer": "1.5平方米",
        "solutionSteps": [
          "长 = 3米，宽 = 50厘米 = 0.5米",
          "面积 = 长 × 宽 = 3 × 0.5 = 1.5平方米"
        ],
        "knowledgePoints": ["长度单位换算", "面积计算"]
      },
      "studentAnswer": {
        "content": "面积 = 3 × 50 = 150平方米",
        "steps": [
          "面积 = 3 × 50 = 150平方米"
        ]
      },
      "expectedAnalysis": {
        "isCorrect": false,
        "errorSteps": [
          {
            "stepNumber": 1,
            "errorType": "unit_conversion_error",
            "errorDescription": "忘记将50厘米转换为0.5米，直接用不同单位的数值相乘",
            "affectedKnowledgePoints": ["长度单位换算"],
            "severity": "critical",
            "correctApproach": "先统一单位：50厘米 = 0.5米，再计算面积：3 × 0.5 = 1.5平方米"
          }
        ]
      },
      "tags": ["unit_conversion_error", "measurement", "critical"]
    }
  ],

  "testScenarios": {
    "teacherBatchAnalysis": {
      "description": "教师批量分析多个学生的答案",
      "quizId": "quiz-test-001",
      "studentAnswers": [
        {
          "studentId": "student-001",
          "answer": "x² - 4 = 0\n(x-2)² = 0\nx = 2"
        },
        {
          "studentId": "student-002",
          "answer": "x² - 4 = 0\n(x+2)(x-2) = 0\nx = -2 或 x = 2"
        },
        {
          "studentId": "student-003",
          "answer": "x² - 4 = 0\n(x-2)² = 0\nx = 2"
        }
      ],
      "expectedOutcome": "识别出 student-001 和 student-003 犯了相同的 formula_misuse 错误，student-002 答案正确"
    },

    "studentSelfCheck": {
      "description": "学生自己检查答案",
      "scenario": "学生做完题后，输入自己的答案让AI分析",
      "expectedBehavior": "AI应该友好地指出错误，不要过于严厉，重点在于帮助理解"
    },

    "errorPatternRecommendation": {
      "description": "基于错误模式推荐练习题",
      "workflow": [
        "1. 分析学生答案，识别错误类型",
        "2. 保存错误分析到数据库",
        "3. 调用 recommend_by_error_pattern 推荐相似题目",
        "4. 展示推荐结果和推荐原因"
      ]
    }
  },

  "validationChecklist": {
    "beforeAnalysis": [
      "题目信息完整（content, correctAnswer, solutionSteps）",
      "学生答案非空",
      "sessionId 有效"
    ],
    "duringAnalysis": [
      "所有 errorType 都是有效的枚举值",
      "errorDescription 具体、可操作",
      "severity 判断合理",
      "correctApproach 明确清晰",
      "stepNumber 对应正确位置"
    ],
    "afterAnalysis": [
      "isCorrect 与 errorSteps 一致",
      "时间戳格式正确（ISO 8601）",
      "所有必需字段完整",
      "affectedKnowledgePoints 准确"
    ]
  },

  "performanceMetrics": {
    "expectedResponseTime": {
      "simple": "< 2秒（单个错误）",
      "moderate": "< 5秒（2-3个错误）",
      "complex": "< 10秒（4+个错误）"
    },
    "accuracyTarget": {
      "errorTypeClassification": "> 85%",
      "stepNumberIdentification": "> 90%",
      "severityJudgment": "> 80%"
    }
  }
}
