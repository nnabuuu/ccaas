{
  "name": "demo-sandbox-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Tiny NestJS backend for the demo-sandbox solution — bootstrap-registers with ccaas core, watches skills/ for hot reload, exposes DocumentEditProvider entity API on :3008.",
  "scripts": {
    "build": "nest build",
    "start": "node --preserve-symlinks dist/main.js",
    "dev": "nest build && node --preserve-symlinks --enable-source-maps dist/main.js",
    "start:dev": "nest build && node --preserve-symlinks --enable-source-maps dist/main.js"
  },
  "dependencies": {
    "@kedge-agentic/context-layer": "file:../../../../packages/context-layer",
    "@kedge-agentic/entity-document": "file:../../../../packages/entity-document",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.22",
    "chokidar": "^3.6.0",
    "gray-matter": "^4.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
