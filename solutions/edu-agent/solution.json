{
  "schemaVersion": "3.0",
  "tenant": {
    "name": "EduAgent",
    "slug": "edu-agent",
    "description": "AI教育助手 - 统一备课设计与讲题解析"
  },
  "mcpServers": {
    "edu-agent-tools": {
      "command": "node",
      "args": ["mcp-server/dist/index.js"],
